{
  "name": "color-namer",
  "displayName": "Color Namer",
  "version": "0.1.1",
  "description": "Name that color. See what the world thinks.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.2.10",
    "@supabase/supabase-js": "^2.101.1",
    "leo-profanity": "^1.9.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "better-sqlite3": "^12.8.0",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://api.datamuse.com/*",
      "https://api.mymemory.translated.net/*"
    ],
    "chrome_url_overrides": {
      "newtab": "tabs/newtab.html"
    }
  }
}
