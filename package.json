{
  "name": "color-namer",
  "displayName": "Color Namer",
  "version": "0.1.0",
  "description": "Name that color. See what the world thinks.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@fontsource/instrument-sans": "^5.0.0",
    "@supabase/supabase-js": "^2.101.1",
    "bad-words": "^4.0.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/bad-words": "^3.0.3",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://api.datamuse.com/*"
    ],
    "chrome_url_overrides": {
      "newtab": "tabs/newtab.html"
    }
  }
}
